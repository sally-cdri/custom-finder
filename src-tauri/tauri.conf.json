{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SallyFinder",
  "version": "0.6.2",
  "identifier": "com.sally.customfinder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SallyFinder",
        "width": 1000,
        "height": 680,
        "minWidth": 720,
        "minHeight": 480,
        "center": true,
        "dragDropEnabled": true,
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/files/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
